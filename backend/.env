
# Loai database: sqlite | supabase
DB_TYPE=sqlite

# Duong dan SQLite (chi dung khi DB_TYPE=sqlite)
DATABASE_URL=file:./dev.db

# JWT secret — doi thanh chuoi ngau nhien dai khi deploy
JWT_SECRET=change-me-to-a-long-random-string-in-production

# Port
PORT=3000

# ==== Logging ====
# Log level: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info

# Pretty print (dev only, tat khi production)
LOG_PRETTY=true
