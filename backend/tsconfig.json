{
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "module": "ESNext",
    "target": "ES2020",
    "esModuleInterop": true,
    "strict": true,
    "useUnknownInCatchVariables": false,
    "types": [
      "node"
    ],
    "moduleResolution": "Bundler"
  },
  "include": [
    "src"
  ]
}
